<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Needed because we spawn the bundled backend node process (Electron used
       as the node binary via ELECTRON_RUN_AS_NODE=1) and embedded-postgres
       which forks `postgres`. Disabling library validation lets these run
       under our signing identity. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <!-- Network access for backend HTTP server + outbound calls (Anthropic API,
       SMTP, IMAP, Telegram, WhatsApp Baileys WebSocket, etc.). -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- Allow reading the user-selected vault directories. -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>

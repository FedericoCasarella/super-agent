# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/super_agent

# Server
PORT=8787
HOST=127.0.0.1

# Claude CLI
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-sonnet-4-6

# Web UI
FRONTEND_ORIGIN=http://localhost:5173

# ClickUp — usato dal "braccio" messaggi cliente (legge le task in "mandare mex
# cliente", pesca il link preview dai commenti, sposta lo stato dopo l'invio).
# Token personale: ClickUp → Settings → Apps → Generate (pk_...).
CLICKUP_API_TOKEN=
# Default per il workspace Performa; cambiare solo se serve.
CLICKUP_TEAM_ID=9015286262
CLICKUP_ASSIGNEE_ID=84001538

# Local dev only — bypass the login screen and auto-authenticate as the single
# local user (or DEV_USER_EMAIL). Leave at 0 for any shared/production build;
# it is also force-disabled when NODE_ENV=production.
DEV_AUTOLOGIN=0
# DEV_USER_EMAIL=mattia@polpo.brain

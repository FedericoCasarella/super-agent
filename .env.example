# Auth (REQUIRED — server refuses to boot without it, see config.ts C1 fail-fast)
# Generate with: openssl rand -base64 32   (must be >= 32 chars)
JWT_SECRET=

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/super_agent

# Server
PORT=8787
HOST=127.0.0.1

# Claude CLI
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-sonnet-4-6

# Web UI
FRONTEND_ORIGIN=http://localhost:5173
